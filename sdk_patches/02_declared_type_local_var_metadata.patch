+AbstractTypePtr LocalVarDescriptors::GetDeclaredType(intptr_t var_index) const {
+  ASSERT(var_index < Length());
+  const Array& declared_types = Array::Handle(ptr()->untag()->declared_types_data());
+  if (declared_types.IsNull() || (declared_types.Length() != Length())) {
+    return AbstractType::null();
+  }
+  const Object& value = Object::Handle(declared_types.At(var_index));
+  if (value.IsNull()) {
+    return AbstractType::null();
+  }
+  ASSERT(value.IsAbstractType());
+  return AbstractType::Cast(value).ptr();
+}
