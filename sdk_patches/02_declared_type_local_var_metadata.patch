+void LocalVarDescriptors::SetDeclaredType(intptr_t var_index,
+                                          const AbstractType& type) const {
+  ASSERT(var_index < Length());
+  Array& declared_types = Array::Handle(ptr()->untag()->declared_types_data());
+  if (declared_types.IsNull() || (declared_types.Length() != Length())) {
+    declared_types = Array::New(Length(), Heap::kOld);
+    ptr()->untag()->set_declared_types_data(declared_types.ptr());
+  }
+  declared_types.SetAt(var_index, type);
+}
+
+void LocalVarDescriptors::SetDeclaredTypes(const Array& types) const {
+  ASSERT(types.IsNull() || (types.Length() == Length()));
+  ptr()->untag()->set_declared_types_data(types.ptr());
+}
