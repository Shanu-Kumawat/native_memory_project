 }
 
+static bool TryGetDeclaredTypeForLocalVariable(
+    ActivationFrame* frame,
+    const String& var_name,
+    const UntaggedLocalVarDescriptors::VarInfo& var_info,
+    AbstractType* declared_type) {
+  ASSERT(declared_type != nullptr);
+#if defined(DART_DYNAMIC_MODULES) && !defined(PRODUCT) &&                      \
+    !defined(DART_PRECOMPILED_RUNTIME)
+  const Bytecode& metadata_bytecode = Bytecode::Handle();
+  bool constrain_by_pc = false;
+  intptr_t pc_offset = 0;
+
+  if (frame->IsInterpreted() && frame->bytecode().HasLocalVariablesInfo()) {
+    metadata_bytecode ^= frame->bytecode();
+    constrain_by_pc = true;
+    pc_offset = frame->pc() - frame->PayloadStart();
+  } else if (frame->function().HasBytecode()) {
+    metadata_bytecode ^= frame->function().GetBytecode();
+  }
+
+  if (metadata_bytecode.IsNull() || !metadata_bytecode.HasLocalVariablesInfo()) {
+    return false;
+  }
+
+  bytecode::BytecodeLocalVariablesIterator local_vars(Thread::Current()->zone(),
+                                                      metadata_bytecode);
+  String& local_name = String::Handle();
+  AbstractType& local_type = AbstractType::Handle();
+  const TokenPosition frame_token_pos = frame->TokenPos();
+  while (local_vars.MoveNext()) {
+    if (!local_vars.IsVariableDeclaration()) {
+      continue;
+    }
+    if (constrain_by_pc &&
+        !((local_vars.StartPC() <= pc_offset) &&
+          (pc_offset <= local_vars.EndPC()))) {
+      continue;
+    }
+    if (!frame_token_pos.IsWithin(local_vars.StartTokenPos(),
+                                  local_vars.EndTokenPos())) {
+      continue;
+    }
+    if (local_vars.Index() != var_info.index()) {
+      continue;
+    }
+    if (local_vars.DeclarationTokenPos() != var_info.declaration_pos ||
+        local_vars.StartTokenPos() != var_info.begin_pos ||
+        local_vars.EndTokenPos() != var_info.end_pos) {
+      continue;
+    }
+    local_name = local_vars.Name();
+    if (!local_name.Equals(var_name)) {
+      continue;
+    }
+    local_type = local_vars.Type();
+    if (local_type.IsNull()) {
+      return false;
+    }
+    *declared_type = local_type.ptr();
+    return true;
+  }
+#else
+  USE(frame);
+  USE(var_name);
+  USE(var_info);
+  USE(declared_type);
+#endif
+  return false;
+}
