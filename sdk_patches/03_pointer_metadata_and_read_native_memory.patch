+// Reads raw bytes from a native memory address using platform APIs that report
+// failures as errors instead of crashing the process.
+
+static const MethodParameter* const read_native_memory_params[] = {
+    RUNNABLE_ISOLATE_PARAMETER,
+    new UIntParameter("address", /*required=*/true),
+    new UIntParameter("count", /*required=*/true),
+    nullptr,
+};
+
+static void ReadNativeMemory(Thread* thread, JSONStream* js) {
+  USE(thread);
+  const uint64_t address =
+      UIntParameter::Parse(js->LookupParam("address"));
+  uint64_t count =
+      UIntParameter::Parse(js->LookupParam("count"));
+
+  // Clamp to 64KB max to prevent abuse.
+  const uint64_t kMaxReadSize = 64 * 1024;
+  if (count > kMaxReadSize) {
+    count = kMaxReadSize;
+  }
+
+  if (address == 0) {
+    js->PrintError(kInvalidParams, "Cannot read from null address (0x0)");
+    return;
+  }
+  if (count == 0) {
+    js->PrintError(kInvalidParams, "Parameter 'count' must be > 0");
+    return;
+  }
+
+  uint8_t* buffer = reinterpret_cast<uint8_t*>(malloc(count));
+  if (buffer == nullptr) {
+    js->PrintError(kInternalError, "Failed to allocate read buffer");
+    return;
+  }
+
+  intptr_t bytes_read = -1;
+
+#if defined(DART_HOST_OS_LINUX) || defined(DART_HOST_OS_ANDROID)
+  // Read from our own process.
+  struct iovec local_iov;
+  local_iov.iov_base = buffer;
+  local_iov.iov_len = count;
+
+  struct iovec remote_iov;
+  remote_iov.iov_base = reinterpret_cast<void*>(address);
+  remote_iov.iov_len = count;
+
+  bytes_read = static_cast<intptr_t>(process_vm_readv(
+      getpid(),
+      &local_iov, 1,
+      &remote_iov, 1,
+      0));
+
+#elif defined(DART_HOST_OS_MACOS)
+  mach_vm_size_t bytes_read_mach = 0;
+  kern_return_t kr = mach_vm_read_overwrite(
+      mach_task_self(),
+      static_cast<mach_vm_address_t>(address),
+      static_cast<mach_vm_size_t>(count),
+      reinterpret_cast<mach_vm_address_t>(buffer),
+      &bytes_read_mach);
+
+  if (kr == KERN_SUCCESS) {
+    bytes_read = static_cast<intptr_t>(bytes_read_mach);
+  } else {
+    bytes_read = -1;
+  }
+
+#elif defined(DART_HOST_OS_WINDOWS)
+  SIZE_T bytes_read_win = 0;
+  BOOL ok = ReadProcessMemory(
+      GetCurrentProcess(),
+      reinterpret_cast<LPCVOID>(address),
+      buffer,
+      static_cast<SIZE_T>(count),
+      &bytes_read_win);
+
+  if (ok) {
+    bytes_read = static_cast<intptr_t>(bytes_read_win);
+  } else {
+    bytes_read = -1;
+  }
+
+#elif defined(DART_HOST_OS_FUCHSIA)
+  // Not yet implemented.
+  bytes_read = -1;
+
+#else
+  // Unknown platform.
+  bytes_read = -1;
+#endif
+
+  if (bytes_read < 0) {
+    free(buffer);
+    js->PrintError(kInternalError,
+                   "Failed to read memory at address 0x%" Px64
+                   ": address may be invalid or unmapped",
+                   address);
+    return;
+  }
+
+  JSONObject response(js);
+  response.AddProperty("type", "NativeMemory");
+  response.AddProperty64("address", static_cast<int64_t>(address));
+  response.AddProperty64("count", static_cast<int64_t>(bytes_read));
+
+  response.AddPropertyBase64("bytes", buffer, bytes_read);
+
+  free(buffer);
+}
